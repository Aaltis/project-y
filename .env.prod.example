# Production environment variables for CRM MVP
#
# Copy this file to .env.prod and fill in all values.
# NEVER commit .env.prod to version control.
#
# Usage: .\scripts\docker\compose-up.ps1 -Env prod
# (the script passes --env-file .env.prod to docker compose)

# ---------------------------------------------------------------------------
# Main application database (shared by customer, accounts, contacts,
# opportunities, activities — each uses its own database on this host)
# Required databases: maindb, accountsdb, contactsdb, opportunitiesdb, activitiesdb
# ---------------------------------------------------------------------------
APP_DB_HOST=your-postgres-host.example.com
APP_DB_PORT=5432
APP_DB_USER=postgres
APP_DB_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Logs database (used by log-consumer service)
# Required database: logsdb
# Required table (created by Flyway on first start):
#   request_log(id, method, path, status, duration_ms, username, created_at)
# ---------------------------------------------------------------------------
LOGS_DB_HOST=your-logs-postgres-host.example.com
LOGS_DB_PORT=5432
LOGS_DB_USER=loguser
LOGS_DB_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Keycloak database
# Required database: keycloak (Keycloak manages its own schema)
# ---------------------------------------------------------------------------
KEYCLOAK_DB_HOST=your-keycloak-postgres-host.example.com
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=changeme
