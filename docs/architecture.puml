@startuml architecture

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam ArrowColor #555555
skinparam ArrowFontSize 10
skinparam componentStyle rectangle
skinparam linetype ortho
skinparam padding 5
skinparam nodesep 40
skinparam ranksep 50

title Project Y — CRM + PMBOK Project Management Architecture (Docker Compose)

' ── Colour palette ───────────────────────────────────────────
skinparam component {
    BackgroundColor<<client>>    #E3F2FD
    BorderColor<<client>>        #1565C0
    FontColor<<client>>          #0D47A1

    BackgroundColor<<config>>    #FFF3E0
    BorderColor<<config>>        #E65100

    BackgroundColor<<gateway>>   #FFF8E1
    BorderColor<<gateway>>       #F57F17

    BackgroundColor<<service>>   #E8F5E9
    BorderColor<<service>>       #2E7D32

    BackgroundColor<<auth>>      #E8EAF6
    BorderColor<<auth>>          #3949AB

    BackgroundColor<<messaging>> #FCE4EC
    BorderColor<<messaging>>     #880E4F

    BackgroundColor<<database>>  #EDE7F6
    BorderColor<<database>>      #4527A0

    BackgroundColor<<job>>       #F3F3F3
    BorderColor<<job>>           #9E9E9E
    FontStyle<<job>>             italic
}

skinparam database {
    BackgroundColor #EDE7F6
    BorderColor     #4527A0
}

' ── External ─────────────────────────────────────────────────
actor "Developer /\nPostman" as dev <<client>>

' ── Docker Compose network ───────────────────────────────────
package "Docker Compose Network" #F5F5F5 {

    ' ── Config layer ─────────────────────────────────────────
    package "Configuration (port 8888)" #FFF3E0 {
        component "**Config Server**\n(Spring Cloud Config, classpath/native)\n\nServes centralised config to ALL\napp services at startup.\n\nconfig/application.properties  — shared:\n  JPA dialect, driver, JWK URI, actuator\n\nconfig/<name>.properties — per-service:\n  datasource URL, RabbitMQ, feature props\n\nClients use fail-fast + 10-attempt\nexponential-backoff retry." as configserver <<config>>
    }

    ' ── Auth layer ───────────────────────────────────────────
    package "Authentication" #E8EAF6 {
        component "**Keycloak 26**\n(Identity Provider)\n\nRealm:  crm\nClient: crm-api  (public)\nRoles:  crm_admin  |  crm_sales\n\nIssues JWT access tokens.\n\nPort 8080 — API\n  /auth/realms/crm/protocol/\n  openid-connect/token\nPort 9000 — management / health" as keycloak <<auth>>

        component "**keycloak-init**\n(one-shot container)\n\nWaits for Keycloak to be healthy,\nthen creates via Admin REST API:\n  testuser  / testpassword  → crm_sales\n  testuser2 / testpassword2 → crm_sales\n\nSkips if users already exist (409)." as keycloakInit <<job>>
    }

    ' ── Messaging layer ──────────────────────────────────────
    package "Messaging (RabbitMQ 3)" #FFF0F5 {
        component "**RabbitMQ**\n\nQueues (both durable):\n\n  request-logs\n    Producer : Gateway (every /api/* request)\n    Consumer : Log Consumer\n\n  opportunity-events\n    Producer : Opportunities (on stage change)\n    Consumer : none yet — for future use\n\nManagement UI : port 15672 (guest/guest)" as rabbitmq <<messaging>>
    }

    ' ── Gateway ──────────────────────────────────────────────
    package "Gateway Layer (port 8080 → host)" #FFFDE7 {
        component "**Spring Cloud Gateway**\n(reactive / WebFlux)\n\nRouting — first match wins:\n  /auth/**                          → Keycloak\n  /api/accounts/*/contacts/**       → Contacts  :8082\n  /api/accounts/**                  → Accounts  :8081\n  /api/opportunities/*/activities/** → Activities :8084\n  /api/opportunities/**             → Opportunities :8083\n  /api/projects/**                  → Projects  :8085\n  /api/customers/**                 → Customer  :8080\n\nGlobal filter on every /api/* request:\n  1. Extract JWT username (Base64-decode JWT payload)\n  2. Rate-limit: 20 req/s per user (Bucket4j in-memory,\n     keyed by JWT preferred_username)\n     → HTTP 429 if exceeded\n  3. Forward to upstream service\n  4. After response: publish RequestLogMessage\n     to request-logs queue (async, best-effort)" as gateway <<gateway>>
    }

    ' ── CRM services ─────────────────────────────────────────
    package "CRM Services" #F1F8E9 {

        component "**Customer**  :8080\n(legacy service)\n\nPOST /api/customers/create\nPUT  /api/customers/edit/{id}\n\nDB: maindb" as customer <<service>>

        component "**Accounts**  :8081\n\nPOST /api/accounts\nGET  /api/accounts\nGET  /api/accounts/{id}\n\nownerId set from JWT sub.\nAccess: @perm.canAccess()\n  crm_admin → full access\n  crm_sales → own records only\n\nDB: accountsdb" as accounts <<service>>

        component "**Contacts**  :8082\n\nCRUD nested under accounts:\n  /api/accounts/{id}/contacts/**\n\nDB: contactsdb" as contacts <<service>>

        component "**Opportunities**  :8083\n\nCRUD /api/opportunities\nPATCH /{id}/stage  (stage workflow)\n\nBusiness rules:\n  • Forward-only stage transitions\n    PROSPECT→QUALIFY→PROPOSE\n    →NEGOTIATE→WON | any→LOST\n  • WON gate: amount + closeDate required\n  • On stage change (best-effort):\n    1. POST NOTE activity to Activities\n       (forwards caller JWT)\n    2. Publish StageChangedEvent\n       to opportunity-events queue\n\nDB: opportunitiesdb" as opportunities <<service>>

        component "**Activities**  :8084\n\nCRUD nested under opportunities:\n  /api/opportunities/{id}/activities/**\n\nAlso receives internal POST\nfrom Opportunities (audit trail).\n\nDB: activitiesdb" as activities <<service>>

        component "**Log Consumer**\n(no HTTP port)\n\nSubscribes to: request-logs queue\n\nFor each message, inserts:\n  request_log(method, path, status,\n  duration_ms, username, timestamp)\n\nErrors caught and logged —\nnever re-queued in a loop.\n\nDB: logsdb" as logconsumer <<messaging>>
    }

    ' ── PMBOK service ────────────────────────────────────────
    package "PMBOK Services" #EDE7F6 {

        component "**Projects**  :8085\n\nFull PMBOK lifecycle:\n  Initiation   → charter + approval\n  Planning     → WBS, tasks, costs,\n                 risks, baselines\n  Execution    → deliverables, work logs,\n                 issues\n  Monitoring   → CRs, decision log,\n                 RAG status reports\n  Closing      → closure report,\n                 lessons learned\n\nPer-project RBAC:\n  @projectPerm.hasRole(#id,'PM',...)\n  userId = Keycloak JWT sub\n\nDB: projectsdb" as projects <<service>>

        component "**Diagrams**  :8086\n\nUser-owned interactive canvas diagrams.\n\nEndpoints:\n  POST   /api/diagrams          (create)\n  GET    /api/diagrams          (list mine)\n  GET    /api/diagrams/{id}     (load with nodes+edges)\n  PUT    /api/diagrams/{id}     (rename)\n  PUT    /api/diagrams/{id}/canvas  (atomic save)\n  DELETE /api/diagrams/{id}\n\nAccess:\n  crm_admin → sees all diagrams\n  crm_sales → own diagrams only\n  (same @perm pattern as CRM services)\n\nDB: diagramsdb" as diagrams <<service>>
    }

    ' ── Databases ────────────────────────────────────────────
    package "Databases (PostgreSQL 13)" #F5F0FF {

        database "**postgres**  (main)\n\nmaindb          → Customer\naccountsdb      → Accounts\ncontactsdb      → Contacts\nopportunitiesdb → Opportunities\nactivitiesdb    → Activities\nprojectsdb      → Projects\ndiagramsdb      → Diagrams\n\nDev: Docker container.\nProd: external host (APP_DB_HOST).\n\nSchema managed by Flyway.\nInit: docker/init-main-db.sql" as maindb <<database>>

        database "**postgres-keycloak**\n\nkeycloak db → Keycloak\n\nKeycloak manages its own schema.\n\nDev: Docker container.\nProd: external (KEYCLOAK_DB_HOST)." as keycloakdb <<database>>

        database "**postgres-logs**\n\nlogsdb → Log Consumer\n\ntable: request_log\n\nDev: Docker container.\nProd: external (LOGS_DB_HOST).\nSeparate instance: different\nretention policy from app data." as logsdb <<database>>
    }
}

' ── External access ───────────────────────────────────────────
dev --> gateway  : HTTPS :8080\nAuthorization: Bearer <JWT>
dev --> rabbitmq : management UI :15672

' ── All services fetch config at startup ─────────────────────
gateway       ..> configserver : fetch config
customer      ..> configserver : fetch config
accounts      ..> configserver : fetch config
contacts      ..> configserver : fetch config
opportunities ..> configserver : fetch config
activities    ..> configserver : fetch config
logconsumer   ..> configserver : fetch config
projects      ..> configserver : fetch config
diagrams      ..> configserver : fetch config

' ── Gateway routing ───────────────────────────────────────────
gateway --> keycloak     : /auth/** (pass-through)
gateway --> customer     : /api/customers/**
gateway --> accounts     : /api/accounts/**
gateway --> contacts     : /api/accounts/*/contacts/**
gateway --> opportunities : /api/opportunities/**
gateway --> activities   : /api/opportunities/*/activities/**
gateway --> projects     : /api/projects/**
gateway --> diagrams     : /api/diagrams/**

' ── JWT validation — all secured services fetch JWK from Keycloak ──
note right of keycloak
  All 6 CRM+PMBOK services validate JWTs
  by fetching public keys from:
  http://keycloak:8080/auth/realms/crm/
  protocol/openid-connect/certs
  (jwk-set-uri, not issuer-uri)
end note

' ── DB connections ────────────────────────────────────────────
customer      --> maindb     : maindb
accounts      --> maindb     : accountsdb
contacts      --> maindb     : contactsdb
opportunities --> maindb     : opportunitiesdb
activities    --> maindb     : activitiesdb
projects      --> maindb     : projectsdb
diagrams      --> maindb     : diagramsdb
keycloak      --> keycloakdb : keycloak db
logconsumer   --> logsdb     : logsdb

' ── Messaging ─────────────────────────────────────────────────
gateway       --> rabbitmq   : publish RequestLogMessage\n→ request-logs (after response)
opportunities --> rabbitmq   : publish StageChangedEvent\n→ opportunity-events (on stage change)
rabbitmq      --> logconsumer : deliver message\n← request-logs

' ── Internal service call ─────────────────────────────────────
opportunities ..> activities : POST /activities (audit NOTE)\nJWT forwarded · best-effort

' ── Auth & init ───────────────────────────────────────────────
keycloakInit  ..> keycloak  : create test users\n(Admin REST API)
keycloak      --> keycloakdb : read/write realm state

@enduml
